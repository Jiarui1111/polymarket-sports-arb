# ============================================================
# 服务器 / 生产环境配置示例（blockhedging-1 等）
# 复制为服务器上的 .env：  cp .env.production.example .env
# 填写真实密码后切勿提交 git
# ============================================================

# ---------- 环境 ----------
DB_ENABLED=true

# ---------- 运行模式 ----------
# 先用 dry_run 跑稳，再改 real
TRADE_MODE=dry_run

# ---------- 链 / 钱包（real 模式必填）----------
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=
POLY_SIGNATURE_TYPE=0
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ---------- API 端点 ----------
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
CHAIN_ID=137

# ---------- 市场发现 ----------
MARKET_TAGS=Sports
MAX_EVENTS=500
MIN_MARKET_LIQUIDITY=500

# ---------- 策略阈值 ----------
MIN_EDGE=0.01
SLIPPAGE_BUFFER=0.005
DEFAULT_ORDER_SIZE=20

# ---------- 风控 ----------
RISK_MAX_ORDER_USD=50
RISK_MAX_EVENT_EXPOSURE_USD=200
RISK_MAX_TOTAL_EXPOSURE_USD=1000
RISK_MIN_EDGE=0.01
RISK_MIN_LIQUIDITY=500
RISK_MAX_SLIPPAGE=0.02
ORDER_TIMEOUT_SEC=20
FEE_RATE=0.0

# ---------- 运行 ----------
SCAN_INTERVAL_SEC=15
LOG_LEVEL=INFO

# ---------- 机会落库：订单簿 5 档 + WS tick ----------
BOOK_LEVEL_DEPTH=5
BOOK_TICK_DEPTH=5

# ---------- PostgreSQL（老板建库后填写）----------
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=polymarket_user
PG_PASSWORD=请填写数据库密码
PG_DATABASE=polymarket_arb
PG_SSLMODE=prefer

# 或使用一行连接串（优先于上面分项）：
# DATABASE_URL=postgresql://polymarket_user:密码@127.0.0.1:5432/polymarket_arb
