# ============================================================
# Polymarket 多 outcome 结构套利程序 - 环境变量配置示例
# 复制为 .env 后填写真实值。切勿把真实 .env 提交到 git！
# ============================================================

# ---------- 运行模式 ----------
# dry_run = 只模拟、不下单（默认，强烈建议先用这个）
# real    = 真实下单（需要下面的钱包/API 凭证 + 风控全部正确）
TRADE_MODE=dry_run

# ---------- 链 / 钱包凭证（只有 real 模式才需要）----------
# 你的 Polygon 钱包私钥（0x 开头）。务必只放在 .env，绝不写进代码或日志。
POLY_PRIVATE_KEY=

# 你在 Polymarket 的代理钱包地址（Email/Magic 登录用 funder 地址）。
# 通过 MetaMask 直连可留空，由私钥推导。
POLY_FUNDER_ADDRESS=

# 签名类型: 0=EOA(私钥直连), 1=Email/Magic, 2=Browser Wallet(代理)
# 大多数通过私钥直接交易的用 0；通过 Polymarket 网站代理钱包用 2。
POLY_SIGNATURE_TYPE=0

# ---------- CLOB API Key（L2 凭证，可由私钥自动派生，留空则自动创建）----------
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ---------- 网络端点（一般无需修改）----------
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
CHAIN_ID=137

# ---------- 市场发现过滤 ----------
# 只关注某些标签（逗号分隔），留空表示不按标签过滤。Sports 体育常见: Sports
MARKET_TAGS=Sports
# 单次拉取事件上限
MAX_EVENTS=500
# 市场最小流动性（USDC），过滤掉太薄的市场
MIN_MARKET_LIQUIDITY=500

# ---------- 套利策略阈值 ----------
# 最小净 edge（已扣除手续费/滑点缓冲），低于此值不输出机会，单位为概率(0-1)
MIN_EDGE=0.01
# 滑点缓冲（保守扣除），单位概率
SLIPPAGE_BUFFER=0.005
# 每个 outcome 默认成交张数（结构套利每条腿数量一致）
DEFAULT_ORDER_SIZE=20

# ---------- 风控（real 模式强制生效）----------
# 单笔订单最大金额 (USDC)
RISK_MAX_ORDER_USD=50
# 单个 event 最大累计暴露 (USDC)
RISK_MAX_EVENT_EXPOSURE_USD=200
# 全局最大累计暴露 (USDC)
RISK_MAX_TOTAL_EXPOSURE_USD=1000
# 最小可接受 edge（风控层二次校验）
RISK_MIN_EDGE=0.01
# 最小流动性要求 (USDC)
RISK_MIN_LIQUIDITY=500
# 最大可接受滑点（概率）
RISK_MAX_SLIPPAGE=0.02
# 订单未成交超时自动撤单（秒）
ORDER_TIMEOUT_SEC=20

# ---------- 手续费 / 成本假设 ----------
# Polymarket 当前 maker/taker 名义手续费（多数市场为 0，留作模型缓冲）
FEE_RATE=0.0

# ---------- 运行参数 ----------
# 扫描间隔（秒）
SCAN_INTERVAL_SEC=15
# 日志级别 DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# ---------- PostgreSQL ----------
# 二选一：完整连接串（优先）或分项配置
# DATABASE_URL=postgresql://user:password@localhost:5432/polymarket_arb
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=polymarket_arb
PG_SSLMODE=prefer

# 机会落库：订单簿档位深度 / WS 最近 tick 条数（每 token 每侧）
BOOK_LEVEL_DEPTH=5
BOOK_TICK_DEPTH=5
